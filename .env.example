# ── Binance credentials (required when EXCHANGE=binance) ──────────────────────
# Create the key with trading enabled, withdrawals DISABLED, and IP-restricted.
# On startup [KEYCHECK] warns if the key can withdraw or isn't IP-restricted.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Refuse to start if the API key can withdraw funds (Binance only). Default: warn only.
STRICT_KEY_CHECK=false

# ── KuCoin Futures credentials (required when EXCHANGE=kucoin) ───────────────
KUCOIN_API_KEY=
KUCOIN_API_SECRET=
KUCOIN_API_PASSPHRASE=
# Override the auto-derived KuCoin symbol (e.g. BTCUSDT → XBTUSDTM).
# Leave blank to use automatic mapping.
KUCOIN_SYMBOL=
# Margin mode for KuCoin Futures orders. Must match your account's setting.
# Values: CROSS (default) or ISOLATED
KUCOIN_MARGIN_MODE=CROSS
# Leverage to use for KuCoin Futures orders
LEVERAGE=1

# ── What to trade ─────────────────────────────────────────────────────────────
# 'binance' or 'kucoin' (KuCoin support is KuCoin Futures only)
EXCHANGE=binance
SYMBOL=BTCUSDT
# Ignored (always treated as true) when EXCHANGE=kucoin
FUTURES_MODE=false

# How much USDT to spend per trade
TRADE_CAPITAL=100
# If > 0, spend this percent of available balance per trade instead of
# TRADE_CAPITAL (e.g. 10 = 10% of available balance)
TRADE_PERCENT=0

# Minimum backtest annualized return (ROA %, over the loaded candle history)
# required for the bot to place new trades with the current params. Checked on
# startup and after every param reload. If the backtest ROA falls below this,
# the bot keeps running (monitors/exits any open position) but stops opening
# new trades until the next reload/restart improves the backtest result.
MIN_ALLOW_PERCENT=500

# Minimum number of historical candles to load before backtesting or live
# trading. The buffer is filled both backward (older history) and forward
# (up to now) until it holds at least this many candles.
MIN_CANDLES=3000

# Maximum candles kept in the rolling buffer. The window grows past MIN_CANDLES
# as new candles arrive but is capped here — oldest candles drop off beyond it.
MAX_CANDLES=10000

# ── Optimizer service ─────────────────────────────────────────────────────────
# URL of the ftrade-optimizer-bot service
OPTIMIZER_URL=http://localhost:4500
# Shared secret — must match REMOTE_OPTIMIZER_KEY on the optimizer service
OPTIMIZER_KEY=

# ── Notify-server (log sink) ──────────────────────────────────────────────────
# When set, every console log is also POSTed to ${NOTIFY_URL}/notify so the
# notify-server durably records it. Leave blank to disable forwarding.
# From inside Docker, reach the host with host.docker.internal.
NOTIFY_URL=http://host.docker.internal:4501

# ── Strategy fallback ─────────────────────────────────────────────────────────
# Used only when the optimizer is unreachable or OPTIMIZER_KEY is unset.
# Normally the bot loads these from the optimizer on every startup.
INTERVAL=1h
FAST_MA=9
SLOW_MA=21
RSI_PERIOD=14
RSI_THRESHOLD=60
STOP_LOSS_PERCENT=2
TAKE_PROFIT_PERCENT=4
TRAILING_PERCENT=0
TRADE_FEE=0.1

# ── Latest backtest result (auto-written) ─────────────────────────────────────
# Written by the bot after every backtest / trade-gate run — do not edit by hand.
# BACKTEST_ANNUAL_RETURN is the ROA compared against MIN_ALLOW_PERCENT.
BACKTEST_CANDLE_LENGTH=
BACKTEST_ANNUAL_RETURN=
BACKTEST_TOTAL_PNL=
BACKTEST_WIN_RATE=
BACKTEST_MAX_DD=
BACKTEST_FINAL_CAPITAL=
BACKTEST_TRADES=
BACKTEST_AT=
